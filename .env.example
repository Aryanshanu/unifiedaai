# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Copy to .env.local and fill in your Supabase project values.
# NEVER commit .env.local to version control.

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# ─── Supabase Edge Function Secrets ───────────────────────────────────────────
# Set via the Supabase CLI — NEVER stored in this file or committed.
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-api03-...
#
# ANTHROPIC_API_KEY
#   Required. Powers every AI feature: column analysis, PDF extraction, RAI
#   evaluations, governance copilot, red-team testing, data quality chat, etc.
#   Get your key → https://console.anthropic.com/
#
# HUGGING_FACE_ACCESS_TOKEN
#   Optional. Used by evaluation engine functions to call user-supplied
#   HuggingFace models for real ML scoring (eval-fairness, eval-toxicity-hf,
#   eval-privacy-hf, eval-hallucination-hf, eval-explainability-hf).
#   Get yours → https://huggingface.co/settings/tokens
